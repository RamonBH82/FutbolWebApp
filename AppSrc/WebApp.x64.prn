36929>>>>>Class cWebSessionManagerStandard is a cWebSessionManager
36930>>>>>    
36930>>>>>    Procedure Construct_Object
36932>>>>>        Handle hoObj
36932>>>>>        
36932>>>>>        Forward Send Construct_Object
36934>>>>>        
36934>>>>>        Set pbSessionCookieHttpOnly to True
36935>>>>>        
36935>>>>>        Property Handle phoUserDD 0      // Handle to the WebAppUser DDO
36936>>>>>        Property Handle phoSessionDD 0   // Handle to the WebAppSession DDO  
36937>>>>>        Property Handle phoCrypto 0      // Handle to the PasswordHasher
36938>>>>>        
36938>>>>>        Get CreateNamed (RefClass(cWebAppUserDataDictionary)) 'oUserDD' to hoObj
36939>>>>>        Set phoUserDD to hoObj
36940>>>>>        
36940>>>>>        Get CreateNamed (RefClass(cWebAppSessionDataDictionary)) 'oSessionDD' to hoObj
36941>>>>>        Set DDO_Server of hoObj to (phoUserDD(Self))
36942>>>>>        Set phoSessionDD to hoObj
36943>>>>>        
36943>>>>>        Property Handle phoCrypto 0   // Handle to the Cryptographer
36944>>>>>        Get CreateNamed (RefClass(cPasswordHasher)) 'oCrypto' to hoObj
36945>>>>>        Set phoCrypto to hoObj
36946>>>>>        
36946>>>>>        Property Boolean pbPasswordHashing True
36947>>>>>        
36947>>>>>        Property Boolean pbCreatingNewSession False
36948>>>>>        Property String psLoginName
36949>>>>>        Property String psUserName ""
36950>>>>>        Property Integer piUserRights 0
36951>>>>>    End_Procedure
36952>>>>>    
36952>>>>>    Procedure End_Construct_Object
36954>>>>>        Forward Send End_Construct_Object
36956>>>>>        
36956>>>>>        Handle hoCrypto
36956>>>>>        Integer iFieldLen
36956>>>>>        If (pbPasswordHashing(Self)) Begin
36958>>>>>            Get phoCrypto to hoCrypto
36959>>>>>            Get_Attribute DF_FIELD_LENGTH of (RefTable(WebAppUser)) (RefTable(WebAppUser.Password)) to iFieldLen
36962>>>>>            If (iFieldLen < (RequiredBufferSize(hoCrypto) + 3)) Begin
36964>>>>>                Error DFERR_PROGRAM "The password field of WebAppUser is not large enough (128)"
36965>>>>>>
36965>>>>>            End
36965>>>>>>
36965>>>>>        End
36965>>>>>>
36965>>>>>    End_Procedure
36966>>>>>    
36966>>>>>    Function CreateSession String sRemoteAddress Returns String
36968>>>>>        String sSessionKey
36968>>>>>        Integer iErr
36968>>>>>        Boolean bLogWebSession
36968>>>>>        Handle hoSessionDD       
36968>>>>>        Get phoSessionDD to hoSessionDD
36969>>>>>        
36969>>>>>        //  Get session key
36969>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
36971>>>>>        
36971>>>>>        Get pbLogWebSession to bLogWebSession
36972>>>>>        If not bLogWebSession Begin
36974>>>>>            Function_Return sSessionKey        
36975>>>>>        End
36975>>>>>>
36975>>>>>
36975>>>>>        //  Store session
36975>>>>>        Send Clear of hoSessionDD
36976>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
36977>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
36978>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
36979>>>>>        Get Request_Validate of hoSessionDD to iErr
36980>>>>>        If (iErr) Begin
36982>>>>>            // this should not happen. If it does its a programming error
36982>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
36983>>>>>>
36983>>>>>            Function_Return ""
36984>>>>>        End
36984>>>>>>
36984>>>>>        Send Request_Save of hoSessionDD
36985>>>>>        If (Err) Begin
36987>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
36987>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
36988>>>>>>
36988>>>>>            Function_Return ""
36989>>>>>        End
36989>>>>>>
36989>>>>>       
36989>>>>>        Function_Return sSessionKey        
36990>>>>>    End_Function
36991>>>>>    
36991>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
36993>>>>>        DateTime dtLastAccess dtCurrent
36993>>>>>        TimeSpan tsDiff
36993>>>>>        Integer iErr iSessionTimeout iSpanMinutes
36993>>>>>        Boolean bResult bCreatingNewSession
36993>>>>>        Boolean bLogWebSession bLoadWebApp
36993>>>>>        Integer eLoginMode
36993>>>>>        String sTime
36993>>>>>        Handle hoSessionDD hoUserDD       
36993>>>>>        
36993>>>>>        Move False to bLoadWebApp
36994>>>>>        If (num_arguments >= 2) Begin
36996>>>>>            Move bOptLoadWebApp to bLoadWebApp
36997>>>>>        End
36997>>>>>>
36997>>>>>        
36997>>>>>        Get phoSessionDD to hoSessionDD
36998>>>>>        Get phoUserDD to hoUserDD
36999>>>>>        
36999>>>>>        Get pbLogWebSession to bLogWebSession
37000>>>>>        Get peLoginMode to eLoginMode
37001>>>>>        
37001>>>>>        // for this object, you can only disable logging if login completely is disabled
37001>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
37003>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
37004>>>>>>
37004>>>>>            Function_Return False
37005>>>>>        End
37005>>>>>>
37005>>>>>
37005>>>>>        //  Clear session properties
37005>>>>>        Set psSessionKey to ""
37006>>>>>        Send UpdateSessionProperties True
37007>>>>>        
37007>>>>>        If not bLogWebSession Begin
37009>>>>>            Forward Get ValidateSession sSessionKey to bResult
37011>>>>>            Function_Return bResult
37012>>>>>        End        
37012>>>>>>
37012>>>>>        
37012>>>>>        Move False to bResult
37013>>>>>        Get piSessionTimeout to iSessionTimeout 
37014>>>>>        
37014>>>>>        //  Check if session exists
37014>>>>>        Send Clear of hoSessionDD
37015>>>>>        Move sSessionKey to WebAppSession.SessionKey
37016>>>>>        Send Find of hoSessionDD EQ Index.1
37017>>>>>            
37017>>>>>        If (Found) Begin
37019>>>>>            //  Calculate timespan between now and last access time
37019>>>>>            Move (CurrentDateTime()) to dtCurrent
37020>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
37021>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
37022>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
37023>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
37024>>>>>            
37024>>>>>            //  Check if session didn't time out
37024>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
37026>>>>>                Forward Get ValidateSession sSessionKey to bResult
37028>>>>>                   
37028>>>>>                If (bResult) Begin
37030>>>>>                    //  Update session record
37030>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
37031>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
37032>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
37033>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
37034>>>>>                    Get Request_Validate of hoSessionDD to iErr
37035>>>>>                    If (iErr) Begin
37037>>>>>                        // this should not happen. If it does its a programming error
37037>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37038>>>>>>
37038>>>>>                        Function_Return False
37039>>>>>                    End
37039>>>>>>
37039>>>>>                    Send Request_Save of hoSessionDD
37040>>>>>                    
37040>>>>>                    //  Update user properties
37040>>>>>                    Send UpdateSessionProperties False
37041>>>>>                End
37041>>>>>>
37041>>>>>            End
37041>>>>>>
37041>>>>>            Else Begin
37042>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
37042>>>>>                Get pbCreatingNewSession to bCreatingNewSession
37043>>>>>                
37043>>>>>                If (not(bCreatingNewSession)) Begin
37045>>>>>                    If (not(bLoadWebApp)) Begin
37047>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
37048>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
37049>>>>>>
37049>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
37050>>>>>                    End
37050>>>>>>
37050>>>>>                    Else Begin
37051>>>>>                        Set pbCreatingNewSession to True                    
37052>>>>>                        Get RecreateSession of ghoWebApp to bResult 
37053>>>>>                        Set pbCreatingNewSession to False                        
37054>>>>>                    End
37054>>>>>>
37054>>>>>                End
37054>>>>>>
37054>>>>>            End
37054>>>>>>
37054>>>>>        End
37054>>>>>>
37054>>>>>        Else Begin
37055>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
37056>>>>>>
37056>>>>>        End
37056>>>>>>
37056>>>>>        
37056>>>>>        Function_Return bResult
37057>>>>>    End_Function
37058>>>>>    
37058>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
37060>>>>>        If (not(pbPasswordHashing(Self))) Begin
37062>>>>>            Move sPassword to sHash
37063>>>>>            Function_Return True
37064>>>>>        End
37064>>>>>>
37064>>>>>        
37064>>>>>        If (not(CreatePasswordHash(phoCrypto(Self), sPassword, &sHash))) Begin
37066>>>>>            Function_Return False
37067>>>>>        End
37067>>>>>>
37067>>>>>        Move ("V1$" + sHash) to sHash
37068>>>>>        Function_Return True
37069>>>>>    End_Function
37070>>>>>    
37070>>>>>    Function VerifyPasswordHash String sUserPassword String sEnteredPassword Boolean ByRef bShouldUpgrade Returns Boolean
37072>>>>>        If (not(pbPasswordHashing(Self))) Begin
37074>>>>>            Move False to bShouldUpgrade
37075>>>>>            Function_Return (sUserPassword = sEnteredPassword)
37076>>>>>        End
37076>>>>>>
37076>>>>>        
37076>>>>>        String sVersion
37076>>>>>        Move (Left(sUserPassword, 3)) to sVersion
37077>>>>>        If (sVersion = "V1$") Begin
37079>>>>>            If (num_arguments > 2) Move False to bShouldUpgrade
37082>>>>>            Function_Return (VerifyPasswordHash(phoCrypto(Self), sEnteredPassword, Right(sUserPassword, Length(sUserPassword) - 3)))
37083>>>>>        End
37083>>>>>>
37083>>>>>        Else Begin
37084>>>>>            If (num_arguments > 2) Move True to bShouldUpgrade
37087>>>>>            Function_Return False
37088>>>>>        End
37088>>>>>>
37088>>>>>    End_Function
37089>>>>>    
37089>>>>>    Function UserRegister String sLoginName String sPassword Returns Boolean
37091>>>>>        Handle hoUserDD
37091>>>>>        Integer iErr
37091>>>>>        Get phoUserDD to hoUserDD
37092>>>>>        
37092>>>>>        //  Find the user
37092>>>>>        Send Clear of hoUserDD
37093>>>>>        Move sLoginName to WebAppUser.LoginName
37094>>>>>        Send Find of hoUserDD EQ Index.1
37095>>>>>        If (Found) Begin
37097>>>>>            Send Clear of hoUserDD
37098>>>>>            Function_Return False
37099>>>>>        End
37099>>>>>>
37099>>>>>        
37099>>>>>        Send Clear of hoUserDD
37100>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.FullName to sLoginName
37101>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.LoginName to sLoginName
37102>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37104>>>>>            Send Clear of hoUserDD
37105>>>>>            Function_Return False
37106>>>>>        End
37106>>>>>>
37106>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37107>>>>>        Get Request_Validate of hoUserDD to iErr
37108>>>>>        If (iErr) Begin
37110>>>>>            Send Clear of hoUserDD
37111>>>>>            Function_Return False
37112>>>>>        End
37112>>>>>>
37112>>>>>        
37112>>>>>        Send Request_Save of hoUserDD
37113>>>>>        Function_Return (not(Err))
37114>>>>>    End_Function
37115>>>>>    
37115>>>>>    Function UserLogin String sLoginName String sPassword Returns Boolean
37117>>>>>        String sSessionKey sUserPassword
37117>>>>>        Handle hoSessionDD hoUserDD
37117>>>>>        Boolean bMatch bUpgrade
37117>>>>>        
37117>>>>>        Get phoSessionDD to hoSessionDD
37118>>>>>        Get phoUserDD to hoUserDD
37119>>>>>        Integer iErr eLoginMode
37119>>>>>        
37119>>>>>        // Refind session record
37119>>>>>        Get psSessionKey to sSessionKey
37120>>>>>        Send Clear of hoSessionDD
37121>>>>>        Move sSessionKey to WebAppSession.SessionKey
37122>>>>>        Send Find of hoSessionDD EQ Index.1
37123>>>>>        
37123>>>>>        If (Found and WebAppSession.SessionKey = sSessionKey) Begin
37125>>>>>            Get peLoginMode to eLoginMode
37126>>>>>            
37126>>>>>            //  Find the user
37126>>>>>            Move sLoginName to WebAppUser.LoginName
37127>>>>>            Send Find of hoUserDD EQ Index.1
37128>>>>>            
37128>>>>>            // Check username and password
37128>>>>>            If (Found and (Lowercase(sLoginName) = Lowercase(Trim(WebAppUser.LoginName)))) Begin
37130>>>>>                Get Field_Current_Value of hoUserDD Field WebAppUser.Password to sUserPassword
37131>>>>>                Get VerifyPasswordHash (Trim(sUserPassword)) (Trim(sPassword)) (&bUpgrade) to bMatch
37132>>>>>                
37132>>>>>                If (bMatch) Begin
37134>>>>>                    // Store the login
37134>>>>>                    If (bUpgrade) Begin
37136>>>>>                        Get CreatePasswordHash (Trim(sPassword)) (&sPassword) to bUpgrade
37137>>>>>                        If (bUpgrade) Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37140>>>>>                    End
37140>>>>>>
37140>>>>>                    Set Field_Changed_Value of hoUserDD Field WebAppUser.LastLogin to (CurrentDateTime())
37141>>>>>                    Get Request_Validate of hoSessionDD to iErr
37142>>>>>                    If (iErr) Begin
37144>>>>>                        // this should not happen. If it does its a programming error
37144>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37145>>>>>>
37145>>>>>                        Function_Return False
37146>>>>>                    End
37146>>>>>>
37146>>>>>                    
37146>>>>>                    Send Request_Save of hoSessionDD
37147>>>>>                    
37147>>>>>                    // Update session properties
37147>>>>>                    Send UpdateSessionProperties False
37148>>>>>                    Send NotifyChangeRights
37149>>>>>                    Function_Return True
37150>>>>>                End
37150>>>>>>
37150>>>>>                Else Begin
37151>>>>>                    //  We should rely directly on this buffer elsewhere but just be sure
37151>>>>>                    Send Clear of hoUserDD
37152>>>>>                End
37152>>>>>>
37152>>>>>            End
37152>>>>>>
37152>>>>>            Else Begin
37153>>>>>                // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37153>>>>>                Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37154>>>>>            End
37154>>>>>>
37154>>>>>        End
37154>>>>>>
37154>>>>>        Else Begin
37155>>>>>            // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37155>>>>>            Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37156>>>>>        End
37156>>>>>>
37156>>>>>          
37156>>>>>        Function_Return False
37157>>>>>    End_Function
37158>>>>>    
37158>>>>>    Function SetUserPassword String sLoginName String sPassword Returns Boolean
37160>>>>>        Handle hoUserDD
37160>>>>>        Integer iErr
37160>>>>>        Get phoUserDD to hoUserDD
37161>>>>>        
37161>>>>>        //  Find the user
37161>>>>>        Send Clear of hoUserDD
37162>>>>>        Move sLoginName to WebAppUser.LoginName
37163>>>>>        Send Find of hoUserDD EQ Index.1
37164>>>>>        If (not(Found)) Begin
37166>>>>>            Send Clear of hoUserDD
37167>>>>>            Function_Return False
37168>>>>>        End
37168>>>>>>
37168>>>>>        
37168>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37170>>>>>            Send Clear of hoUserDD
37171>>>>>            Function_Return False
37172>>>>>        End
37172>>>>>>
37172>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37173>>>>>        Get Request_Validate of hoUserDD to iErr
37174>>>>>        If (iErr) Begin
37176>>>>>            Send Clear of hoUserDD
37177>>>>>            Function_Return False
37178>>>>>        End
37178>>>>>>
37178>>>>>        
37178>>>>>        Send Request_Save of hoUserDD
37179>>>>>        Function_Return (not(Err))
37180>>>>>    End_Function
37181>>>>>    
37181>>>>>    Function IsLoggedIn Returns Boolean
37183>>>>>        String sLoginName
37183>>>>>        Boolean bLogWebSession bLoggedIn
37183>>>>>        
37183>>>>>        Get pbLogWebSession to bLogWebSession
37184>>>>>        If not bLogWebSession Begin
37186>>>>>            Forward Get IsLoggedIn to bLoggedIn
37188>>>>>            Function_Return bLoggedIn
37189>>>>>        End
37189>>>>>>
37189>>>>>        
37189>>>>>        Get psLoginName to sLoginName
37190>>>>>        
37190>>>>>        Function_Return (sLoginName <> "")
37191>>>>>    End_Function
37192>>>>>    
37192>>>>>    
37192>>>>>    //
37192>>>>>    // This procedure is called when validating a session and after logging in. Its purpose is to 
37192>>>>>    // update properties based on the session and user data. Augment this function to update 
37192>>>>>    // properties based on the session / user table. Note that WebAppUser and WebAppSession contain
37192>>>>>    // the right records when this procedure is called.
37192>>>>>    //
37192>>>>>    // Params:
37192>>>>>    //      bClear   True if the procedure is called before session validation to clear properties.
37192>>>>>    //
37192>>>>>    Procedure UpdateSessionProperties Boolean bClear
37194>>>>>        Handle hoUserDD
37194>>>>>        
37194>>>>>        Get phoUserDD to hoUserDD
37195>>>>>        
37195>>>>>        //  Update user properties
37195>>>>>        If (not(bClear) and HasRecord(hoUserDD)) Begin
37197>>>>>            Set psUsername to (Trim(WebAppUser.FullName))
37198>>>>>            Set psLoginName to (Trim(WebAppUser.LoginName))
37199>>>>>            Set piUserRights to WebAppUser.Rights
37200>>>>>            
37200>>>>>            Send OnSessionPropertiesSet 
37201>>>>>        End
37201>>>>>>
37201>>>>>        Else Begin
37202>>>>>            Set psUsername to ""
37203>>>>>            Set psLoginName to ""
37204>>>>>            Set piUserRights to 0
37205>>>>>            
37205>>>>>            Send OnSessionPropertiesClear
37206>>>>>        End
37206>>>>>>
37206>>>>>    End_Procedure
37207>>>>>    
37207>>>>>    Procedure OnSessionPropertiesSet
37209>>>>>        //  Empty event stub
37209>>>>>    End_Procedure
37210>>>>>    
37210>>>>>    Procedure OnSessionPropertiesClear
37212>>>>>        //  Empty event stub
37212>>>>>    End_Procedure
37213>>>>>    
37213>>>>>    Procedure EndSession
37215>>>>>        Integer iErr
37215>>>>>        Boolean bLogWebSession
37215>>>>>        Handle hoSessionDD       
37215>>>>>        
37215>>>>>        Get phoSessionDD to hoSessionDD
37216>>>>>        Get pbLogWebSession to bLogWebSession
37217>>>>>        If not bLogWebSession Begin
37219>>>>>            Forward Send EndSession
37221>>>>>            Procedure_Return
37222>>>>>        End
37222>>>>>>
37222>>>>>            
37222>>>>>        //  Check if session exists
37222>>>>>        Send Clear of hoSessionDD
37223>>>>>        Get psSessionKey to WebAppSession.SessionKey
37224>>>>>        
37224>>>>>        Send Find of hoSessionDD EQ Index.1
37225>>>>>        If (Found) Begin
37227>>>>>            Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "N"
37228>>>>>            Get Request_Validate of hoSessionDD to iErr
37229>>>>>            If (iErr) Begin
37231>>>>>                // this should not happen. If it does its a programming error
37231>>>>>                Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37232>>>>>>
37232>>>>>                Procedure_Return
37233>>>>>            End
37233>>>>>>
37233>>>>>            Send Request_Save of hoSessionDD
37234>>>>>        End
37234>>>>>>
37234>>>>>    End_Procedure
37235>>>>>
37235>>>>>End_Class
