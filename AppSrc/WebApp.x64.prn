37750>>>    Procedure SetActionButtons
37753>>>        tWebNavigateData NavigateData
37753>>>        tWebNavigateData NavigateData
37753>>>        Boolean bHasRecord
37753>>>        Handle hoDD
37753>>>
37753>>>        Get Server to hoDD
37754>>>        Get GetNavigateData to NavigateData
37755>>>        Get HasRecord of hoDD to bHasRecord
37756>>>
37756>>>        // let's hide all buttons and then Show the ones we want
37756>>>        WebSet pbRender of oEditBtn to False
37757>>>        WebSet pbRender of oSaveBtn to False
37758>>>        WebSet pbRender of oCancelChangesBtn to False
37759>>>        WebSet pbRender of oDeleteBtn to False
37760>>>
37760>>>        If (NavigateData.bReadOnly) Begin
37762>>>            WebSet pbRender of oEditBtn to True
37763>>>        End
37763>>>>
37763>>>        Else Begin
37764>>>            WebSet pbRender of oSaveBtn to True
37765>>>            WebSet pbRender of oCancelChangesBtn to True
37766>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37767>>>        End
37767>>>>
37767>>>    End_Procedure
37768>>>
37768>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
37771>>>        // Close after save
37771>>>        Send NavigateClose Self
37772>>>    End_Procedure
37773>>>
37773>>>    // this will close the view after a delete
37773>>>    Procedure OnViewDeleted Handle hoDDO
37776>>>        Send NavigateClose Self
37777>>>    End_Procedure
37778>>>
37778>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37781>>>        Case Begin
37781>>>            Case (NavigateData.eNavigateType = nfFromMain)
37783>>>                // If from main, this is a propbably a main file Select to Zoom.
37783>>>                Case Break
37784>>>
37784>>>            Case (NavigateData.eNavigateType = nfFromParent)
37787>>>                // If from parent, this is a constrained drill down.
37787>>>                Case Break
37788>>>
37788>>>            Case (NavigateData.eNavigateType = nfFromChild)
37791>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37791>>>                Case Break
37792>>>
37792>>>            Case Else // must be nfUndefined
37792>>>
37792>>>        Case End
37792>>>
37792>>>        Send SetActionButtons
37793>>>
37793>>>    End_Procedure
37794>>>
37794>>>End_Object 
