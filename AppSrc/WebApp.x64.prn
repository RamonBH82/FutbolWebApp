38225>>>        Boolean bHasRecord
38225>>>        Handle hoDD
38225>>>
38225>>>        Get Server to hoDD
38226>>>        Get GetNavigateData to NavigateData
38227>>>        Get HasRecord of hoDD to bHasRecord
38228>>>
38228>>>        // let's hide all buttons and then Show the ones we want
38228>>>        WebSet pbRender of oEditBtn to False
38229>>>        WebSet pbRender of oSaveBtn to False
38230>>>        WebSet pbRender of oCancelChangesBtn to False
38231>>>        WebSet pbRender of oDeleteBtn to False
38232>>>
38232>>>        If (NavigateData.bReadOnly) Begin
38234>>>            WebSet pbRender of oEditBtn to True
38235>>>        End
38235>>>>
38235>>>        Else Begin
38236>>>            WebSet pbRender of oSaveBtn to True
38237>>>            WebSet pbRender of oCancelChangesBtn to True
38238>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38239>>>        End
38239>>>>
38239>>>    End_Procedure
38240>>>
