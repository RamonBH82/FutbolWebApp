37846>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37849>>>        Case Begin
37849>>>            Case (NavigateData.eNavigateType = nfFromMain)
37851>>>                // If from main, this is a propbably a main file Select to Zoom.
37851>>>                Case Break
37852>>>
37852>>>            Case (NavigateData.eNavigateType = nfFromParent)
37855>>>                // If from parent, this is a constrained drill down.
37855>>>                Case Break
37856>>>
37856>>>            Case (NavigateData.eNavigateType = nfFromChild)
37859>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37859>>>                Case Break
37860>>>
37860>>>            Case Else // must be nfUndefined
37860>>>
37860>>>        Case End
37860>>>
37860>>>        Send SetActionButtons
37861>>>
37861>>>    End_Procedure
37862>>>
37862>>>End_Object 
