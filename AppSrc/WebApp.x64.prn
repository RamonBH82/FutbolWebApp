37347>>>    Procedure OnLoad
37350>>>        String sPrevStateHash sView
37350>>>        
37350>>>        Forward Send OnLoad
37352>>>        
37352>>>        //  Store the current state so we can go back to that later (only if it points to a different view)
37352>>>        Get StateHash of ghoWebApp to sPrevStateHash
37353>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37354>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37356>>>            WebSet psPrevStateHash to sPrevStateHash
37357>>>        End
37357>>>>
37357>>>        
37357>>>    End_Procedure
