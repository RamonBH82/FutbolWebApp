37643>>>
37643>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37646>>>        Case Begin
37646>>>            Case (NavigateData.eNavigateType = nfFromMain)
37648>>>                // If from main, this is a propbably a main file Select to Zoom.
37648>>>                Case Break
37649>>>
37649>>>            Case (NavigateData.eNavigateType = nfFromParent)
37652>>>                // If from parent, this is a constrained drill down.
37652>>>                Case Break
37653>>>
37653>>>            Case (NavigateData.eNavigateType = nfFromChild)
37656>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37656>>>                Case Break
37657>>>
37657>>>            Case Else // must be nfUndefined
37657>>>
37657>>>        Case End
37657>>>
37657>>>        Send SetActionButtons
37658>>>
37658>>>    End_Procedure
37659>>>
37659>>>End_Object 
