37615>>>    Procedure SetActionButtons
37618>>>        tWebNavigateData NavigateData
37618>>>        tWebNavigateData NavigateData
37618>>>        Boolean bHasRecord
37618>>>        Handle hoDD
37618>>>
37618>>>        Get Server to hoDD
37619>>>        Get GetNavigateData to NavigateData
37620>>>        Get HasRecord of hoDD to bHasRecord
37621>>>
37621>>>        // let's hide all buttons and then Show the ones we want
37621>>>        WebSet pbRender of oEditBtn to False
37622>>>        WebSet pbRender of oSaveBtn to False
37623>>>        WebSet pbRender of oCancelChangesBtn to False
37624>>>        WebSet pbRender of oDeleteBtn to False
37625>>>
37625>>>        If (NavigateData.bReadOnly) Begin
37627>>>            WebSet pbRender of oEditBtn to True
37628>>>        End
37628>>>>
37628>>>        Else Begin
37629>>>            WebSet pbRender of oSaveBtn to True
37630>>>            WebSet pbRender of oCancelChangesBtn to True
37631>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37632>>>        End
37632>>>>
37632>>>    End_Procedure
