36615>>>>>>>    //
36615>>>>>>>    //  Converts the given time to an string that can be saved in the database.
36615>>>>>>>    //
36615>>>>>>>    //  Params:
36615>>>>>>>    //      dtTime  Time to convert
36615>>>>>>>    //  Returns:
36615>>>>>>>    //      String with "HH:MM:SS" format
36615>>>>>>>    //
36615>>>>>>>    Function TimeToString DateTime dtTime Returns String
36617>>>>>>>        String sHours sMinutes sSeconds
36617>>>>>>>        
36617>>>>>>>        //  Extract parts
36617>>>>>>>        Move (String(DateGetHour(dtTime))) to sHours
36618>>>>>>>        Move (String(DateGetMinute(dtTime))) to sMinutes
36619>>>>>>>        Move (String(DateGetSecond(dtTime))) to sSeconds
36620>>>>>>>        
36620>>>>>>>        //  Fill out with 0
36620>>>>>>>        If (Length(sHours) = 1) ;            Move ("0" + sHours) to sHours
36623>>>>>>>        If (Length(sMinutes) = 1) ;            Move ("0" + sMinutes) to sMinutes
36626>>>>>>>        If (Length(sSeconds) = 1) ;            Move ("0" + sSeconds) to sSeconds
36629>>>>>>>        
36629>>>>>>>        Function_Return (sHours + ":" + sMinutes + ":" + sSeconds)
36630>>>>>>>    End_Function
36631>>>>>>>    
36631>>>>>>>    //
36631>>>>>>>    //  Sets the time of the datetime variable to the time in the string.
36631>>>>>>>    //
36631>>>>>>>    //  Params:
36631>>>>>>>    //      dtTime  Datetime variable to add time to
36631>>>>>>>    //      sTimeString String with time in the format "HH:MM:SS"
36631>>>>>>>    //  Returns:
36631>>>>>>>    //      dtDateTime with the loaded time
36631>>>>>>>    //
36631>>>>>>>    Function StringToTime DateTime dtTime String sTimeString Returns DateTime
36633>>>>>>>        String sHours sMinutes sSeconds
36633>>>>>>>        
36633>>>>>>>        //  Extract parts
36633>>>>>>>        Move (Mid(sTimeString, 2, 1)) to sHours
36634>>>>>>>        Move (Mid(sTimeString, 2, 4)) to sMinutes
36635>>>>>>>        Move (Mid(sTimeString, 2, 7)) to sSeconds
36636>>>>>>>        
36636>>>>>>>        //  Set to DateTime
36636>>>>>>>        Move (DateSetHour(dtTime, (Integer(sHours)))) to dtTime
36637>>>>>>>        Move (DateSetMinute(dtTime, (Integer(sMinutes)))) to dtTime
36638>>>>>>>        Move (DateSetSecond(dtTime, (Integer(sSeconds)))) to dtTime
36639>>>>>>>        
36639>>>>>>>        Function_Return dtTime
36640>>>>>>>    End_Function
