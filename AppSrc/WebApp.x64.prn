37323>>>    Procedure DoLogin
37326>>>        String sLoginName sPassword sPrevStateHash
37326>>>        Boolean bResult
37326>>>        
37326>>>        WebGet psValue of oLoginName to sLoginName
37327>>>        WebGet psValue of oPassword to sPassword
37328>>>        
37328>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37329>>>        
37329>>>        If (bResult) Begin
37331>>>            Send Hide of oLogin
37332>>>            Send ShowHeader of ghoWebApp
37333>>>            WebSet psCSSClass of ghoWebApp to ""
37334>>>            
37334>>>            WebGet psPrevStateHash to sPrevStateHash
37335>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37336>>>            
37336>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37336>>>            WebSet psValue of oLoginName to ""
37337>>>            WebSet psValue of oPassword  to ""
37338>>>            WebSet pbVisible of oWarning to False
37339>>>        End
37339>>>>
37339>>>        Else Begin
37340>>>            WebSet pbVisible of oWarning to True
37341>>>        End
37341>>>>
37341>>>    End_Procedure
37342>>>    
37342>>>    Procedure OnSubmit
37345>>>        Send DoLogin
37346>>>    End_Procedure
