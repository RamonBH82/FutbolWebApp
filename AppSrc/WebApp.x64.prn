36744>>>>>>>    Function Base64DecodeArr String sBase64 Returns UChar[]
36746>>>>>>>        Integer iLen
36746>>>>>>>        Pointer pBase64
36746>>>>>>>        UChar[] ucaBuffer
36747>>>>>>>        Move (Base64Decode(AddressOf(sBase64), &iLen)) to pBase64
36748>>>>>>>        If (not(pBase64)) Begin
36750>>>>>>>            Function_Return ucaBuffer
36751>>>>>>>        End
36751>>>>>>>>
36751>>>>>>>        
36751>>>>>>>        Move (ResizeArray(ucaBuffer, iLen)) to ucaBuffer
36752>>>>>>>        Move (MemCopy(AddressOf(ucaBuffer), pBase64, iLen)) to iLen
36753>>>>>>>        Move (Free(pBase64)) to iLen
36754>>>>>>>        Function_Return ucaBuffer
36755>>>>>>>    End_Function
36756>>>>>>>    
36756>>>>>>>    Function CreatePasswordHashExWithSalt UInteger uiAlgo UChar[] ucaSalt String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36758>>>>>>>        Boolean bOk bRequireTimeCost
36758>>>>>>>        UChar[] ucaHash
36759>>>>>>>        
36759>>>>>>>        Case Begin
36759>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36761>>>>>>>                Get CNG_PBKDF2_HMAC "SHA256" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36762>>>>>>>                If (not(bOk)) Function_Return False
36765>>>>>>>                
36765>>>>>>>                Move True to bRequireTimeCost
36766>>>>>>>                Case Break
36767>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36770>>>>>>>                Get CNG_PBKDF2_HMAC "SHA512" (StringToUCharArray(sPassword)) ucaSalt uiOptTimeCost (&ucaHash) False to bOk
36771>>>>>>>                If (not(bOk)) Function_Return False
36774>>>>>>>                
36774>>>>>>>                Move True to bRequireTimeCost
36775>>>>>>>                Case Break
36776>>>>>>>            Case Else
36776>>>>>>>                Error 8710 "Invalid algorithm selected."
36777>>>>>>>>
36777>>>>>>>                Function_Return False
36778>>>>>>>        Case End
36778>>>>>>>        
36778>>>>>>>        String sSalt
36778>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36779>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return False
36782>>>>>>>        Get Base64EncodeArr ucaHash to sHash
36783>>>>>>>        If (not(SizeOfString(sHash))) Function_Return False
36786>>>>>>>        
36786>>>>>>>        If (bRequireTimeCost) Begin
36788>>>>>>>            Move (SFormat("%1$%2$%3$%4",            ;                            String(uiAlgo),         ;                            sSalt,                  ;                            String(uiOptTimeCost),  ;                            sHash)) to sHash
36789>>>>>>>        End
36789>>>>>>>>
36789>>>>>>>        Else Begin
36790>>>>>>>            Move (SFormat("%1$%2$%3",               ;                            String(uiAlgo),         ;                            sSalt,                  ;                            sHash)) to sHash
36791>>>>>>>        End
36791>>>>>>>>
36791>>>>>>>        
36791>>>>>>>        Function_Return bOk
36792>>>>>>>    End_Function
36793>>>>>>>    
36793>>>>>>>    Function CreatePasswordHashEx UInteger uiAlgo UInteger uiSaltSize String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36795>>>>>>>        UChar[] ucaSalt
36796>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36797>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36800>>>>>>>        
36800>>>>>>>        If (num_arguments > 4) Begin
36802>>>>>>>            Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash, uiOptTimeCost))
36803>>>>>>>        End
36803>>>>>>>>
36803>>>>>>>        Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash))
36804>>>>>>>    End_Function
36805>>>>>>>    
36805>>>>>>>    Function VerifyPasswordHash String sPassword String sHash Returns Boolean
36807>>>>>>>        Boolean bRequiresTimeCost
36807>>>>>>>        UInteger uiAlgo uiTimeCost
36807>>>>>>>        Integer iBegin iEnd
36807>>>>>>>        String sSalt
36807>>>>>>>        
36807>>>>>>>        Move 1 to iBegin
36808>>>>>>>        
36808>>>>>>>        // Parse Algo
36808>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36809>>>>>>>        If (not(iEnd)) Function_Return False
36812>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiAlgo
36813>>>>>>>        
36813>>>>>>>        // Parse Salt
36813>>>>>>>        Move (iEnd + 1) to iBegin
36814>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36815>>>>>>>        If (not(iEnd)) Function_Return False
36818>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to sSalt
36819>>>>>>>        
36819>>>>>>>        Case Begin
36819>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36821>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36824>>>>>>>                Move True to bRequiresTimeCost
36825>>>>>>>                Case Break
36826>>>>>>>            Case Else
36826>>>>>>>                Error 8710 "Invalid algorithm selected."
36827>>>>>>>>
36827>>>>>>>                Function_Return False
36828>>>>>>>        Case End
36828>>>>>>>        
36828>>>>>>>        // Parse optional timecost
36828>>>>>>>        If (bRequiresTimeCost) Begin
36830>>>>>>>            Move (iEnd + 1) to iBegin
36831>>>>>>>            Move (Pos("$", sHash, iBegin)) to iEnd
36832>>>>>>>            If (not(iEnd)) Function_Return False
36835>>>>>>>            Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiTimeCost
36836>>>>>>>        End
36836>>>>>>>>
36836>>>>>>>        
36836>>>>>>>        // Parse rest hash
36836>>>>>>>        Move (iEnd + 1) to iBegin
36837>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36838>>>>>>>        If (iEnd) Function_Return False // inverse check if there are any other errors.
36841>>>>>>>        
36841>>>>>>>        // Base64Decode
36841>>>>>>>        UChar[] ucaSalt
36842>>>>>>>        Get Base64DecodeArr sSalt to ucaSalt
36843>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36846>>>>>>>        
36846>>>>>>>        // Create new hash
36846>>>>>>>        String sNewHash
36846>>>>>>>        If (bRequiresTimeCost) Begin
36848>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash, uiTimeCost))) Begin
36850>>>>>>>                Function_Return False 
36851>>>>>>>            End
36851>>>>>>>>
36851>>>>>>>        End
36851>>>>>>>>
36851>>>>>>>        Else Begin
36852>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash))) Begin
36854>>>>>>>                Function_Return False 
36855>>>>>>>            End
36855>>>>>>>>
36855>>>>>>>        End
36855>>>>>>>>
36855>>>>>>>        Function_Return (sNewHash = sHash)
36856>>>>>>>    End_Function
36857>>>>>>>    
36857>>>>>>>    Function RequiredBufferSizeEx UInteger uiAlgo UInteger uiSaltSize UInteger uiOptTimeCost Returns UBigInt
36859>>>>>>>        Boolean bRequireTimeCost
36859>>>>>>>        UBigInt ullSize
36859>>>>>>>        UChar[] ucaSalt
36860>>>>>>>        String sSalt
36860>>>>>>>        
36860>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36861>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36862>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return 0
36865>>>>>>>        
36865>>>>>>>        Case Begin
36865>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36867>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA256" to ullSize
36868>>>>>>>                Move True to bRequireTimeCost
36869>>>>>>>                Case Break
36870>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36873>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA512" to ullSize
36874>>>>>>>                Move True to bRequireTimeCost
36875>>>>>>>                Case Break
36876>>>>>>>            Case Else
36876>>>>>>>                Error 8710 "Invalid algorithm selected."
36877>>>>>>>>
36877>>>>>>>                Function_Return 0
36878>>>>>>>        Case End
36878>>>>>>>        
36878>>>>>>>        // calculate base64 in a non-floating-manner
36878>>>>>>>        Move (((ullSize + 3 -1) / 3) * 4) to ullSize
36879>>>>>>>        
36879>>>>>>>        Move (ullSize + SizeOfString(String(uiAlgo))) to ullSize
36880>>>>>>>        Move (ullSize + SizeOfString(sSalt)) to ullSize
36881>>>>>>>        If (bRequireTimeCost) Begin
36883>>>>>>>            Move (ullSize + SizeOfString(String(uiOptTimeCost))) to ullSize
36884>>>>>>>            Move (ullSize + 3 /*$*/) to ullSize
36885>>>>>>>        End
36885>>>>>>>>
36885>>>>>>>        Else Begin
36886>>>>>>>            Move (ullSize + 2 /*$*/) to ullSize
36887>>>>>>>        End
36887>>>>>>>>
36887>>>>>>>        
36887>>>>>>>        Function_Return ullSize
36888>>>>>>>    End_Function
36889>>>>>>>End_Class
36890>>>>>>>
36890>>>>>>>Class cPasswordHasher is a cObject
36891>>>>>>>    
36891>>>>>>>    Import_Class_Protocol cPasswordHasher_Mixin
36892>>>>>>>    
36892>>>>>>>    Procedure Construct_Object
36894>>>>>>>        Forward Send Construct_Object
36896>>>>>>>        
36896>>>>>>>        Property UInteger   peAlgorithm         C_PWH_PBKDF2_HMAC_SHA_512 
36897>>>>>>>        Property UInteger   puiSaltSize         16
36898>>>>>>>        
36898>>>>>>>        Property UInteger   puiOptTimeCost      420000
36899>>>>>>>    End_Procedure
36900>>>>>>>    
36900>>>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36902>>>>>>>        Boolean bOk
36902>>>>>>>        UInteger uiAlgo
36902>>>>>>>        Get peAlgorithm to uiAlgo
36903>>>>>>>        
36903>>>>>>>        Case Begin
36903>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36905>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36908>>>>>>>                Get CreatePasswordHashEx uiAlgo (puiSaltSize(Self)) sPassword (&sHash) (puiOptTimeCost(Self)) to bOk
36909>>>>>>>                Case Break
36910>>>>>>>            Case Else
36910>>>>>>>                Error 8710 "Invalid algorithm selected."
36911>>>>>>>>
36911>>>>>>>                Function_Return False
36912>>>>>>>        Case End
36912>>>>>>>        
36912>>>>>>>        Function_Return bOk
36913>>>>>>>    End_Function
36914>>>>>>>    
36914>>>>>>>    Function RequiredBufferSize Returns UBigInt
36916>>>>>>>        UBigInt ullSize
36916>>>>>>>        UInteger uiAlgo
36916>>>>>>>        Get peAlgorithm to uiAlgo
36917>>>>>>>        
36917>>>>>>>        Case Begin
36917>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36919>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36922>>>>>>>                Get RequiredBufferSizeEx uiAlgo (puiSaltSize(Self)) (puiOptTimeCost(Self)) to ullSize
36923>>>>>>>                Case Break
36924>>>>>>>            Case Else
36924>>>>>>>                Error 8710 "Invalid algorithm selected."
36925>>>>>>>>
36925>>>>>>>                Function_Return 0
36926>>>>>>>        Case End
36926>>>>>>>        
36926>>>>>>>        Function_Return ullSize
36927>>>>>>>    End_Function
36928>>>>>>>
36928>>>>>>>End_Class
